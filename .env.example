# MiniMax API Configuration
MINIMAX_API_KEY=your-api-key-here

# API Host (choose one based on your region):
# Global: https://api.minimax.io
# China: https://api.minimaxi.com
MINIMAX_API_HOST=https://api.minimax.io

# Optional: SQLite database path (default: ~/.minimax-cli/tasks.db)
# MINIMAX_DB_PATH=~/.minimax-cli/tasks.db

# Optional: Default output directory (default: ./downloads)
# MINIMAX_OUTPUT_DIR=./downloads
